# Copy to .env and fill in. Never commit .env.

# Obsidian account credentials (Sync subscription required, MFA must be off).
OBSIDIAN_EMAIL=you@example.com
OBSIDIAN_PASSWORD=your-account-password

# Comma-separated remote vault names, each optionally Name:e2e-password.
# Example: Work:secret1,Personal
OBSIDIAN_VAULTS=Work

# Optional: end-to-end encryption password for vaults without their own.
#OBSIDIAN_VAULT_PASSWORD=

# Bearer token MCP clients must send. Generate: openssl rand -hex 32
MCP_AUTH_TOKEN=change-me

# Optional: stable device name shown in Obsidian Sync version history.
# Defaults to ObsidianMCP-<8 random hex chars> per boot.
#OBSIDIAN_DEVICE_NAME=obsidian-mcp-prod

# Optional: host port to publish (container always listens on 8080).
#PORT=8080
