# Copy to .env and fill in. Never commit .env.

# Obsidian account credentials (Sync subscription required, MFA must be off).
OBSIDIAN_EMAIL=you@example.com
OBSIDIAN_PASSWORD=your-account-password

# Comma-separated remote vault names, each optionally Name:e2e-password.
# Example: Work:secret1,Personal
OBSIDIAN_VAULTS=Work

# Optional: end-to-end encryption password for vaults without their own.
#OBSIDIAN_VAULT_PASSWORD=

# Static bearer token (API key) MCP clients may send. Generate:
# openssl rand -hex 32. Optional when OAUTH_ISSUER is configured.
MCP_AUTH_TOKEN=change-me

# --- Optional: delegate auth to an OpenID Connect identity provider ---
# Setting OAUTH_ISSUER enables OAuth: bearer JWTs from this issuer are
# accepted (alongside MCP_AUTH_TOKEN if that is also set). Works with any
# OIDC-compliant provider (Keycloak, Auth0, Entra ID, ...).
#OAUTH_ISSUER=https://idp.example.com/realms/myrealm
# Audience the token must carry in aud (or azp). Required with OAUTH_ISSUER.
#OAUTH_AUDIENCE=obsidian-mcp
# This server's public URL — advertised to MCP clients as the protected
# resource identifier. Required with OAUTH_ISSUER.
#MCP_PUBLIC_URL=https://obsidian.example.com
# Where to fetch discovery/JWKS from when the public issuer is not
# reachable from inside your network (e.g. a cluster-internal URL).
#OAUTH_INTERNAL_ISSUER=http://keycloak.infra.svc.cluster.local:8080/realms/myrealm
# Scopes advertised in the protected-resource metadata.
# Default: openid,profile,email
#OAUTH_SCOPES=openid,profile,email

# Optional: stable device name shown in Obsidian Sync version history.
# Defaults to ObsidianMCP-<8 random hex chars> per boot.
#OBSIDIAN_DEVICE_NAME=obsidian-mcp-prod

# Optional: host port to publish (container always listens on 8080).
#PORT=8080
